@{
    Layout = null;
    ViewData["Title"] = "Email potvrđen";
}
<!DOCTYPE html>
<html lang="bs">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ParkirajBa – Email potvrđen</title>
    <link rel="stylesheet" href="/css/site.css" />
</head>
<body>
    <div class="auth-page">
        <div class="auth-overlay"></div>
        <div class="auth-content">
            <img src="/images/logo.png" class="auth-logo" alt="ParkirajBa" />

            <div class="auth-card" style="text-align: center;">
                <div style="margin-bottom: 16px;">
                    <svg viewBox="0 0 24 24" width="56" height="56" fill="#28a745">
                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" />
                    </svg>
                </div>

                <h2 style="margin: 0 0 12px; color: #28a745;">Email potvrđen!</h2>
                <p style="color: #666; font-size: 15px; line-height: 1.6; margin: 0 0 28px;">
                    Vaš nalog je uspješno aktiviran.<br />
                    Sada možete koristiti sve funkcije ParkirajBa.
                </p>

                <a href="/Home/Index" class="btn-blue" style="width: 100%; justify-content: center; box-sizing: border-box;">
                    Idi na početnu
                </a>
            </div>
        </div>
    </div>
</body>
</html>
