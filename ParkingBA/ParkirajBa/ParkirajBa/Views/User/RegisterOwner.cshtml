@{
    Layout = "_Layout";
    ViewData["Title"] = "Register";
}

<div class="auth-container">
    <h2>Registracija vlasnika parkinga</h2>
    @if (ViewBag.Error != null)
    {
        <div style="color:red; margin-bottom:10px;">
            @ViewBag.Error
        </div>
    }
    <form method="post" action="/User/RegisterOwner">
        <input type="text" name="ime" placeholder="Ime" />
        <input type="text" name="prezime" placeholder="Prezime" />
        <input type="email" name="email" placeholder="Email" />
        <input type="password" name="password" placeholder="Password" />
        <input type="password" name="confirmPassword" placeholder="Potvrdi password" />

        <button type="submit">Registruj se</button>
    </form>

    <p>Već imate račun?</p>
    <a href="/User/Login">Login</a>

    <p>Želite registrovati parking?</p>

    <a class="owner-register-btn" href="/User/RegisterOwner">
        Registracija vlasnika parkinga
    </a>
</div>

<style>
    .auth-container {
        width: 320px;
        margin: 100px auto;
        text-align: center;
    }

    input {
        width: 100%;
        margin: 8px 0;
        padding: 10px;
    }

    button {
        width: 100%;
        padding: 10px;
        background: #28a745;
        color: white;
        border: none;
    }
</style>