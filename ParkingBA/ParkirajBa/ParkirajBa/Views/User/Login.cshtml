@{
    ViewData["Title"] = "Login";
}

<div class="auth-container">
    <h2>Login</h2>

    <form method="post" action="/User/Login">
        <input type="email" name= "email" placeholder="Email" />
        <input type="password" name="password" placeholder="Password" />

        <button type="submit">Login</button>
    </form>

    <p>Nemate račun?</p>
    <a href="/User/Register">Registruj se</a>
</div>

<style>
    .auth-container {
        width: 320px;
        margin: 100px auto;
        text-align: center;
    }

    input {
        width: 100%;
        margin: 8px 0;
        padding: 10px;
    }

    button {
        width: 100%;
        padding: 10px;
        background: #007bff;
        color: white;
        border: none;
    }
</style>