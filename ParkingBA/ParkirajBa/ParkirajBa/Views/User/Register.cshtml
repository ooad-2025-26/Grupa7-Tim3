@{
    Layout = "_Layout";
    ViewData["Title"] = "Register";
}

<div class="auth-page">

    <div class="auth-overlay"></div>

    <div class="auth-content">

        <img class="auth-logo" src="/images/logo.png" />

        <div class="auth-card">

            <h2>Registracija</h2>

            @if (ViewBag.Error != null)
            {
                <div class="error-message">
                    @ViewBag.Error
                </div>
            }

            <form method="post" action="/User/Register">

                <input type="text"
                       name="ime"
                       placeholder="Ime" />

                <input type="text"
                       name="prezime"
                       placeholder="Prezime" />

                <input type="email"
                       name="email"
                       placeholder="Email" />

                <input type="password"
                       name="password"
                       placeholder="Password" />

                <input type="password"
                       name="confirmPassword"
                       placeholder="Potvrdi password" />

                <button type="submit">
                    Registracija putem Email-a
                </button>

            </form>

            <div class="auth-divider">
                <span>ili</span>
            </div>

            <a class="secondary-auth-btn"
               href="/User/Login">

                Već imate račun?

            </a>

            <a class="owner-auth-btn"
               href="/User/RegisterOwner">

                Registracija vlasnika parkinga

            </a>

        </div>
    </div>
</div>