@model List<ParkirajBa.Controllers.ParkingStatViewModel>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Izvještaj – Vlasnik";
}

<div class="app-container">

    <div class="tabs">
        <div class="tab"><a href="/Home/Index">Mapa</a></div>
        <div class="tab active"><a href="/Parking/ParkingManagement">Objekti</a></div>
        <div class="tab"><a href="/Home/Rezervacije">Rezervacije</a></div>
    </div>

    <div class="rezervacije-container">

        <!-- HEADER -->
        <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; margin-bottom: 24px;">
            <div>
                <h2 style="margin: 0 0 4px;">Izvještaj — Moji parking objekti</h2>
                <p style="margin: 0; color: #777; font-size: 14px;">@ViewBag.OwnerName &nbsp;·&nbsp; Generisano: @ViewBag.GeneratedAt</p>
            </div>
            <div style="display: flex; gap: 10px;">
                <a href="/Report/OwnerReportExcel" class="btn-gray" style="padding: 9px 20px; font-size: 13px; border-radius: 20px; display: inline-flex; align-items: center; gap: 6px;">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.89 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm-1 7V3.5L18.5 9H13zm-2 8l-3-3h2v-4h2v4h2l-3 3z" /></svg>
                    Excel
                </a>
                <a href="/Report/OwnerReportPdf" class="btn-blue" style="padding: 9px 20px; font-size: 13px; border-radius: 20px; display: inline-flex; align-items: center; gap: 6px;">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="white"><path d="M20 2H8c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-8.5 7.5c0 .83-.67 1.5-1.5 1.5H9v2H7.5V7H10c.83 0 1.5.67 1.5 1.5v1zm5 2c0 .83-.67 1.5-1.5 1.5h-2.5V7H15c.83 0 1.5.67 1.5 1.5v3zm4-3H19v1h1.5V11H19v2h-1.5V7h3v1.5zM9 9.5h1v-1H9v1zM4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6zm10 5.5h1v-3h-1v3z" /></svg>
                    PDF
                </a>
            </div>
        </div>

        <!-- SUMMARY KARTICE -->
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 16px; margin-bottom: 28px;">
            <div class="stat-card">
                <div class="stat-value">@ViewBag.TotalParkings</div>
                <div class="stat-label">Parkinga</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">@ViewBag.TotalTickets</div>
                <div class="stat-label">Ukupno tiketa</div>
            </div>
            <div class="stat-card">
                <div class="stat-value" style="color: #28a745;">@(((decimal)ViewBag.RevenueThisMonth).ToString("0.00")) KM</div>
                <div class="stat-label">Prihod ovaj mj.</div>
            </div>
            <div class="stat-card">
                <div class="stat-value" style="color: #6287f9;">@(((decimal)ViewBag.TotalRevenue).ToString("0.00")) KM</div>
                <div class="stat-label">Ukupni prihod</div>
            </div>
        </div>

        <!-- KARTICE PO PARKINGU -->
        @if (Model == null || !Model.Any())
        {
            <div class="empty-state">
                <p>Nemate registrovanih parkinga.</p>
                <a href="/Parking/ParkingManagement" class="btn-blue" style="margin-top: 16px;">Upravljaj parkingom</a>
            </div>
        }
        else
        {
            @foreach (var s in Model)
            {
                var occColor = s.OccupancyPercent >= 80 ? "#dc3545" : s.OccupancyPercent >= 50 ? "#fd7e14" : "#28a745";
                var occBg = s.OccupancyPercent >= 80 ? "#f8d7da" : s.OccupancyPercent >= 50 ? "#fff3cd" : "#d4edda";

                <div style="background: white; border-radius: 16px; padding: 24px 28px; box-shadow: 0 3px 12px rgba(0,0,0,0.07); margin-bottom: 20px;">

                    <!-- Naziv + status -->
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 10px; margin-bottom: 18px;">
                        <div>
                            <h3 style="margin: 0 0 4px; font-size: 17px; color: #222;">@(s.Parking.name ?? "—")</h3>
                            <p style="margin: 0; font-size: 13px; color: #777;">📍 @(s.Parking.address ?? "—")</p>
                        </div>
                        <span style="background: @occBg; color: @occColor; padding: 5px 14px; border-radius: 20px; font-size: 12px; font-weight: 700;">
                            @s.OccupancyPercent.ToString("0.0")% popunjeno
                        </span>
                    </div>

                    <!-- Traka iskorištenosti -->
                    <div style="margin-bottom: 18px;">
                        <div style="display: flex; justify-content: space-between; font-size: 12px; color: #aaa; margin-bottom: 5px;">
                            <span>Iskorištenost kapaciteta</span>
                            <span>@s.ActiveTickets / @s.Parking.totalSpots mjesta</span>
                        </div>
                        <div style="height: 8px; background: #f0f0f0; border-radius: 4px; overflow: hidden;">
                            <div style="height: 100%; width: @s.OccupancyPercent.ToString("0.0")%; background: @occColor; border-radius: 4px; transition: width 0.4s;"></div>
                        </div>
                    </div>

                    <!-- Metrike -->
                    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 12px;">
                        <div class="mini-stat">
                            <div class="mini-val">@s.TotalTickets</div>
                            <div class="mini-lbl">Ukupno tiketa</div>
                        </div>
                        <div class="mini-stat">
                            <div class="mini-val" style="color: #28a745;">@s.ActiveTickets</div>
                            <div class="mini-lbl">Aktivnih sad</div>
                        </div>
                        <div class="mini-stat">
                            <div class="mini-val">@s.RevenueLastMonth.ToString("0.00") KM</div>
                            <div class="mini-lbl">Prošli mj.</div>
                        </div>
                        <div class="mini-stat">
                            <div class="mini-val" style="color: #28a745;">@s.RevenueThisMonth.ToString("0.00") KM</div>
                            <div class="mini-lbl">Ovaj mj.</div>
                        </div>
                        <div class="mini-stat">
                            <div class="mini-val" style="color: #6287f9;">@s.TotalRevenue.ToString("0.00") KM</div>
                            <div class="mini-lbl">Ukupni prihod</div>
                        </div>
                    </div>

                </div>
            }
        }

    </div>
</div>

<style>
    .stat-card {
        background: white;
        border-radius: 12px;
        padding: 20px 22px;
        box-shadow: 0 3px 10px rgba(0,0,0,0.06);
        text-align: center;
    }

    .stat-value {
        font-size: 26px;
        font-weight: 700;
        color: #6287f9;
        margin-bottom: 4px;
    }

    .stat-label {
        font-size: 11px;
        color: #aaa;
        text-transform: uppercase;
        letter-spacing: 0.4px;
    }

    .mini-stat {
        background: #f8f9fa;
        border-radius: 10px;
        padding: 12px 14px;
        text-align: center;
    }

    .mini-val {
        font-size: 16px;
        font-weight: 700;
        color: #333;
        margin-bottom: 2px;
    }

    .mini-lbl {
        font-size: 11px;
        color: #aaa;
        text-transform: uppercase;
        letter-spacing: 0.3px;
    }
</style>
