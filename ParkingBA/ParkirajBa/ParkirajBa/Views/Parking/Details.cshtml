@model ParkirajBa.Models.ParkingObject
@{
    Layout = "_Layout";
    ViewData["Title"] = Model.name;

    var pricings = ViewBag.Pricings as List<ParkirajBa.Models.Pricing> ?? new();
    bool isOpen = false;
    if (Model.opensAt.HasValue && Model.closesAt.HasValue)
    {
        var now = DateTime.Now.TimeOfDay;
        isOpen = now >= Model.opensAt.Value.TimeOfDay && now <= Model.closesAt.Value.TimeOfDay;
    }
}

<div class="app-container">

    <div class="tabs">
        <div class="tab"><a href="/Home/Index">Mapa</a></div>
        <div class="tab active"><a href="/Home/Objekti">Objekti</a></div>
        <div class="tab"><a href="/Home/Rezervacije">Rezervacije</a></div>
    </div>

    <div class="rezervacije-container">

        <div style="margin-bottom: 24px;">
            <a href="/Home/Objekti" style="color: #6287f9; font-size: 14px; display: inline-flex; align-items: center; gap: 4px;">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="#6287f9"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z" /></svg>
                Nazad na objekte
            </a>
        </div>

        <div style="background: white; border-radius: 16px; overflow: hidden; box-shadow: 0 3px 14px rgba(0,0,0,0.08); margin-bottom: 20px;">
            @{
                var slika = ViewBag.PrimaryImage as ParkirajBa.Models.ParkingImage;
            }
            <img src="@(slika?.ImagePath ?? "/images/parking.png")" alt="Slika objekta - @Model.name"
                 style="width: 100%; height: 220px; object-fit: cover;" />

            <div style="padding: 28px 32px;">
                <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 12px; margin-bottom: 16px;">
                    <div>
                        <h2 style="margin: 0 0 6px; font-size: 24px; color: #222;">@Model.name</h2>
                        <p style="margin: 0; color: #888; font-size: 14px; display: flex; align-items: center; gap: 4px;">
                            <svg viewBox="0 0 24 24" width="14" height="14" fill="#aaa"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" /></svg>
                            @Model.address
                        </p>
                    </div>
                    @if (Model.opensAt.HasValue && Model.closesAt.HasValue)
                    {
                        <span style="background: @(isOpen ? "#d4edda" : "#f8d7da"); color: @(isOpen ? "#155724" : "#721c24"); padding: 6px 16px; border-radius: 20px; font-size: 13px; font-weight: 600;">
                            @(isOpen ? "● Otvoreno" : "● Zatvoreno")
                        </span>
                    }
                </div>

                <div class="object-badges" style="margin-bottom: 20px;">
                    @if (Model.hasCameras == true)
                    {
                        <span class="badge-feature">📷 Video nadzor</span>
                    }
                    @if (Model.hasEVCharger == true)
                    {
                        <span class="badge-feature">⚡ EV punjač</span>
                    }
                    @if (Model.isDisabledAccessible == true)
                    {
                        <span class="badge-feature">♿ Pristupačno</span>
                    }
                    @if (Model.isUnderground == true)
                    {
                        <span class="badge-feature">🏢 Podzemni parking</span>
                    }
                </div>

                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 14px;">

                    <div class="parking-info-item">
                        <svg viewBox="0 0 24 24" width="22" height="22" fill="#6287f9">
                            <path d="M18.92 6.01C18.72 5.42 18.16 5 17.5 5h-11c-.66 0-1.21.42-1.42 1.01L3 12v8c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-1h12v1c0 .55.45 1 1 1h1c.55 0 1-.45 1-1v-8l-2.08-5.99zM6.5 16c-.83 0-1.5-.67-1.5-1.5S5.67 13 6.5 13s1.5.67 1.5 1.5S7.33 16 6.5 16zm11 0c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zM5 11l1.5-4.5h11L19 11H5z" />
                        </svg>
                        <div>
                            <div style="font-size: 11px; color: #aaa; text-transform: uppercase; letter-spacing: 0.4px;">Slobodna mjesta</div>
                            <div style="font-weight: 600; color: #333; font-size: 15px;">@Model.availableSpots / @Model.totalSpots</div>
                        </div>
                    </div>

                    @if (Model.opensAt.HasValue && Model.closesAt.HasValue)
                    {
                        <div class="parking-info-item">
                            <svg viewBox="0 0 24 24" width="22" height="22" fill="#6287f9">
                                <path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z" />
                            </svg>
                            <div>
                                <div style="font-size: 11px; color: #aaa; text-transform: uppercase; letter-spacing: 0.4px;">Radno vrijeme</div>
                                <div style="font-weight: 600; color: #333; font-size: 15px;">@Model.opensAt.Value.ToString("HH:mm") – @Model.closesAt.Value.ToString("HH:mm")</div>
                            </div>
                        </div>
                    }

                    @if (Model.maxHeight.HasValue)
                    {
                        <div class="parking-info-item">
                            <svg viewBox="0 0 24 24" width="22" height="22" fill="#6287f9">
                                <path d="M16 4H8v2h8V4zm2 4H6v2h12V8zm-2 4H8v2h8v-2zm2 4H6v2h12v-2z" />
                            </svg>
                            <div>
                                <div style="font-size: 11px; color: #aaa; text-transform: uppercase; letter-spacing: 0.4px;">Maks. visina</div>
                                <div style="font-weight: 600; color: #333; font-size: 15px;">@Model.maxHeight.Value.ToString("0.0") m</div>
                            </div>
                        </div>
                    }

                </div>

                @{
                    double occ = (Model.totalSpots.HasValue && Model.totalSpots.Value > 0)
                    ? Math.Min((double)(Model.totalSpots.Value - Model.availableSpots) / Model.totalSpots.Value * 100, 100) : 0;

                    string occColor = occ >= 80 ? "#dc3545" : occ >= 50 ? "#fd7e14" : "#28a745";
                }
                <div style="margin-top: 20px;">
                    <div style="display: flex; justify-content: space-between; font-size: 12px; color: #aaa; margin-bottom: 6px;">
                        <span>Zauzetost</span>
                        <span style="color: @occColor; font-weight: 600;">@occ.ToString("0")%</span>
                    </div>
                    <div style="height: 8px; background: #f0f0f0; border-radius: 4px; overflow: hidden;">
                        <div style="height: 100%; width: @occ.ToString("0.0")%; background: @occColor; border-radius: 4px;"></div>
                    </div>
                </div>

            </div>
        </div>

        @if (pricings.Any())
        {
            <div style="background: white; border-radius: 16px; padding: 28px 32px; box-shadow: 0 3px 14px rgba(0,0,0,0.07); margin-bottom: 20px;">
                <h3 style="margin: 0 0 18px; font-size: 16px; color: #333; font-weight: 600;">Cjenovnik</h3>
                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 12px;">
                    @foreach (var p in pricings.OrderBy(p => p.pricingType))
                    {
                        string tipString = p.pricingType.ToString().ToLower();

                        string prevedeniTip = tipString switch
                        {
                            "hourly" or "posatu" or "po satu" => "Po satu",
                            "daily" or "podanu" or "po danu" => "Po danu",
                            "weekly" or "posedmici" or "po sedmici" => "Sedmično",
                            "monthly" or "mjesecno" or "mjesečno" => "Mjesečno",
                            "yearly" or "godisnje" or "godišnje" => "Godišnje",
                            _ => "Standardno"
                        };

                        <div style="background: #f4f7ff; border-radius: 12px; padding: 16px; text-align: center;">
                            <div style="font-size: 11px; color: #aaa; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px;">
                                @prevedeniTip
                            </div>
                            <div style="font-size: 18px; font-weight: 700; color: #333;">
                                @p.price.ToString("0.00") KM
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <div style="display: flex; gap: 12px; flex-wrap: wrap;">
            @if (Model.availableSpots > 0)
            {
                <a href="/Reservation/Create?parkingObjectId=@Model.ID" class="btn-blue" style="padding: 12px 28px;">
                    Rezerviši parking
                </a>
            }
            else
            {
                <span class="btn-gray" style="padding: 12px 28px; opacity: 0.6; cursor: not-allowed;">
                    Nema dostupnih mjesta
                </span>
            }
        </div>

    </div>
</div>

<style>
    .parking-info-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 16px;
        background: #f8f9fa;
        border-radius: 10px;
    }

    .badge-feature {
        background: #f0f4ff;
        color: #4a67d6;
        padding: 4px 10px;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 500;
        display: inline-block;
        margin-right: 6px;
        margin-bottom: 6px;
    }
</style>
