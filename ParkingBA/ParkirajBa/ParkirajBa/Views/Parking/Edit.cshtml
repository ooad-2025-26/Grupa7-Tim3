@model ParkirajBa.Models.ParkingObject

@{
    Layout = "_Layout";
    ViewData["Title"] = "Uredi parking";
    bool isAdmin = User.IsInRole("Admin");
    string backUrl = isAdmin ? "/Admin/Parkings" : "/Parking/ParkingManagement";
}

<div style="max-width:720px;margin:40px auto;padding:0 20px;">
    <a href="@backUrl" style="color:#6287f9;text-decoration:none;font-size:13px;">← Nazad</a>
    <h2 style="margin:8px 0 24px;font-size:22px;font-weight:700;">Uredi parking</h2>

    @if (ViewBag.Error != null)
    {
        <div style="background:#fdf0f0;color:#dc3545;border:1px solid #f5c6cb;border-radius:8px;padding:12px 16px;margin-bottom:20px;">
            ⚠ @ViewBag.Error
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div style="background:#f0fdf4;color:#16a34a;border:1px solid #bbf7d0;border-radius:8px;padding:12px 16px;margin-bottom:20px;">
            ✓ @TempData["Success"]
        </div>
    }

    <div style="background:white;border-radius:16px;padding:32px;box-shadow:0 2px 12px rgba(0,0,0,0.07);">
        <form method="post" action="/Parking/Edit/@Model.ID">
            @Html.AntiForgeryToken()

            <div style="margin-bottom:16px;">
                <label style="display:block;font-size:13px;font-weight:600;margin-bottom:6px;color:#555;">Naziv parkinga *</label>
                <input type="text" name="name" value="@Model.name" required
                       style="width:100%;padding:11px 14px;border:1px solid #ddd;border-radius:8px;font-size:14px;box-sizing:border-box;" />
            </div>

            <div style="margin-bottom:16px;">
                <label style="display:block;font-size:13px;font-weight:600;margin-bottom:6px;color:#555;">Adresa</label>
                <input type="text" name="address" value="@Model.address"
                       style="width:100%;padding:11px 14px;border:1px solid #ddd;border-radius:8px;font-size:14px;box-sizing:border-box;" />
            </div>

            <div style="display:flex;gap:16px;margin-bottom:16px;">
                <div style="flex:1;">
                    <label style="display:block;font-size:13px;font-weight:600;margin-bottom:6px;color:#555;">Ukupno mjesta *</label>
                    <input type="number" name="totalSpots" value="@Model.totalSpots" min="1" required
                           style="width:100%;padding:11px 14px;border:1px solid #ddd;border-radius:8px;font-size:14px;box-sizing:border-box;" />
                </div>
                <div style="flex:1;">
                    <label style="display:block;font-size:13px;font-weight:600;margin-bottom:6px;color:#555;">Maks. visina (m)</label>
                    <input type="number" name="maxHeight" value="@Model.maxHeight" step="0.1" min="0"
                           style="width:100%;padding:11px 14px;border:1px solid #ddd;border-radius:8px;font-size:14px;box-sizing:border-box;" />
                </div>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:24px;">
                <label style="display:flex;align-items:center;gap:10px;padding:12px;background:#f8f9fa;border-radius:8px;cursor:pointer;">
                    <input type="checkbox" name="hasCameras" value="true" @(Model.hasCameras == true ? "checked" : "") style="width:16px;height:16px;" />
                    <span style="font-size:14px;">📷 Video nadzor</span>
                </label>
                <label style="display:flex;align-items:center;gap:10px;padding:12px;background:#f8f9fa;border-radius:8px;cursor:pointer;">
                    <input type="checkbox" name="hasEVCharger" value="true" @(Model.hasEVCharger == true ? "checked" : "") style="width:16px;height:16px;" />
                    <span style="font-size:14px;">⚡ EV punjač</span>
                </label>
                <label style="display:flex;align-items:center;gap:10px;padding:12px;background:#f8f9fa;border-radius:8px;cursor:pointer;">
                    <input type="checkbox" name="isDisabledAccessible" value="true" @(Model.isDisabledAccessible == true ? "checked" : "") style="width:16px;height:16px;" />
                    <span style="font-size:14px;">♿ Invalidski pristup</span>
                </label>
                <label style="display:flex;align-items:center;gap:10px;padding:12px;background:#f8f9fa;border-radius:8px;cursor:pointer;">
                    <input type="checkbox" name="isUnderground" value="true" @(Model.isUnderground == true ? "checked" : "") style="width:16px;height:16px;" />
                    <span style="font-size:14px;">🏢 Garaža</span>
                </label>
            </div>

            <div style="display:flex;justify-content:flex-end;gap:12px;">
                <a href="@backUrl"
                   style="padding:11px 24px;background:#f1f3f5;color:#555;border-radius:8px;text-decoration:none;font-size:14px;font-weight:600;">
                    Odustani
                </a>
                <button type="submit"
                        style="padding:11px 28px;background:#6287f9;color:white;border:none;border-radius:8px;font-size:14px;font-weight:600;cursor:pointer;">
                    Sačuvaj izmjene
                </button>
            </div>
        </form>
    </div>
</div>
