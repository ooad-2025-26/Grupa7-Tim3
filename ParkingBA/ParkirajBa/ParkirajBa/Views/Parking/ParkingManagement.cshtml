@model List<ParkirajBa.Models.ParkingObject>

@{
    Layout = "_Layout";
    ViewData["Title"] = "Upravljanje parkinzima";
}

<div class="app-container">

    <!-- NAV -->
    <div class="tabs">
        <div class="tab">
            <a href="/Home/Index">🗺️ Mapa</a>
        </div>

        <div class="tab active">
            <a href="/Parking/ParkingManagement">🅿️ Objekti</a>
        </div>

        <div class="tab">
            <a href="/Home/Rezervacije">🎫 Rezervacije</a>
        </div>
    </div>

    <div class="management-container">

        <!-- LEFT SIDE -->
        <div class="sidebar">

            @foreach (var parking in Model)
            {
                <div class="parking-card">

                    <img src="~/images/parking.jpg" />

                    <div class="parking-info">
                        <h4>@parking.name</h4>

                        <p>@parking.address</p>

                        <small>
                            Slobodna mjesta:
                            @parking.availableSpots / @parking.totalSpots
                        </small>
                    </div>

                </div>
            }

            <button class="add-button">
                + Dodaj parking
            </button>

        </div>

        <!-- RIGHT SIDE -->
        <div class="editor-panel">

            <h2>Upravljanje objektima</h2>

            <input type="text" placeholder="Naziv" class="custom-input" />

            <input type="text" placeholder="Adresa" class="custom-input" />

            <div class="input-row">

                <input type="number"
                       placeholder="Ukupno mjesta"
                       class="custom-input" />

                <input type="number"
                       placeholder="Slobodna mjesta"
                       class="custom-input" />

            </div>

            <div class="checkboxes">

                <label>
                    <input type="checkbox" />
                    EV punjač
                </label>

                <label>
                    <input type="checkbox" />
                    Video nadzor
                </label>

                <label>
                    <input type="checkbox" />
                    Invalidski pristup
                </label>

                <label>
                    <input type="checkbox" />
                    Garaža
                </label>

            </div>

            <textarea placeholder="Opis"
                      class="description-box"></textarea>

            <div class="buttons">

                <button class="save-button">
                    Sačuvaj izmjene
                </button>

                <button class="delete-button">
                    Ukloni
                </button>

            </div>

        </div>

    </div>
</div>

<style>

    body {
        margin: 0;
        background: #f5f5f5;
        font-family: 'Segoe UI';
    }

    .tabs {
        display: flex;
        gap: 10px;
        padding: 15px 40px;
        background: #f8f9fa;
    }

    .tab {
        padding: 10px 20px;
        border-radius: 30px;
        background: #e9ecef;
    }

        .tab.active {
            background: #6287f9;
        }

        .tab a {
            color: black;
            text-decoration: none;
        }

        .tab.active a {
            color: white;
        }

    .management-container {
        display: flex;
        gap: 20px;
        padding: 20px;
    }

    .sidebar {
        width: 350px;
        background: white;
        border-radius: 12px;
        padding: 15px;
    }

    .parking-card {
        display: flex;
        gap: 15px;
        padding: 10px;
        margin-bottom: 15px;
        border-radius: 10px;
        background: #f8f9fa;
        cursor: pointer;
    }

        .parking-card img {
            width: 90px;
            height: 70px;
            object-fit: cover;
            border-radius: 8px;
        }

    .parking-info h4 {
        margin: 0;
    }

    .add-button {
        width: 100%;
        padding: 12px;
        border: none;
        border-radius: 10px;
        background: #6287f9;
        color: white;
        cursor: pointer;
    }

    .editor-panel {
        flex: 1;
        background: white;
        border-radius: 12px;
        padding: 25px;
    }

    .custom-input {
        width: 100%;
        padding: 12px;
        margin-bottom: 15px;
        border: 1px solid #ddd;
        border-radius: 8px;
    }

    .input-row {
        display: flex;
        gap: 15px;
    }

    .checkboxes {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 10px;
        margin: 20px 0;
    }

    .description-box {
        width: 100%;
        height: 120px;
        border: 1px solid #ddd;
        border-radius: 8px;
        padding: 12px;
    }

    .buttons {
        display: flex;
        justify-content: flex-end;
        gap: 15px;
        margin-top: 20px;
    }

    .save-button {
        background: #1a73e8;
        color: white;
        border: none;
        padding: 12px 20px;
        border-radius: 8px;
    }

    .delete-button {
        background: #dc3545;
        color: white;
        border: none;
        padding: 12px 20px;
        border-radius: 8px;
    }

</style>