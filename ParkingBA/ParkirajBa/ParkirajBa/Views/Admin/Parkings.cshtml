@model IEnumerable<ParkirajBa.Models.ParkingObject>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Upravljanje parkinzima";
}
<div style="min-height:100vh;background:var(--bg);padding:28px 36px;">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;">
        <div>
            <a href="/Admin/Dashboard" style="color:var(--accent);font-size:13px;text-decoration:none;">← Nazad na panel</a>
            <h1 style="margin:4px 0 0;font-size:24px;font-weight:700;color:var(--text);">Upravljanje parkinzima</h1>
        </div>
        <span style="background:var(--accent);color:white;padding:6px 16px;border-radius:20px;font-size:13px;font-weight:600;">@Model.Count() lokacija</span>
    </div>
    @if (TempData["Success"] != null)
    {
        <div class="adm-alert-success">✓ @TempData["Success"]</div>
    }

    <div class="adm-card" style="padding:0;overflow:hidden;">
        <table class="adm-table">
            <thead><tr><th>Naziv</th><th>Adresa</th><th>Vlasnik</th><th>Mjesta</th><th>Oprema</th><th>Akcije</th></tr></thead>
            <tbody>
                @foreach (var p in Model)
                {
                    double occ = p.totalSpots > 0 ? (double)(p.totalSpots.Value - p.availableSpots) / p.totalSpots.Value * 100 : 0;
                    string occColor = occ >= 80 ? "#dc3545" : occ >= 50 ? "#fd7e14" : "#28a745";
                    <tr>
                        <td style="font-weight:600;">@p.name</td>
                        <td style="color:var(--text2);font-size:12px;">@p.address</td>
                        <td style="font-size:12px;color:var(--text3);">@(p.Owner?.FullName ?? "—")</td>
                        <td>
                            <span style="font-weight:600;color:var(--text);">@p.availableSpots/@p.totalSpots</span>
                            <div style="height:4px;background:var(--surface2);border-radius:2px;margin-top:4px;width:80px;">
                                <div style="height:100%;width:@occ.ToString("0.0")%;background:@occColor;border-radius:2px;"></div>
                            </div>
                        </td>
                        <td style="font-size:14px;">
                            @if (p.hasCameras == true)
                            {
                                <span title="Video nadzor">📷 </span>
                            }
                            @if (p.hasEVCharger == true)
                            {
                                <span title="EV punjač">⚡ </span>
                            }
                            @if (p.isDisabledAccessible == true)
                            {
                                <span title="Pristupačno">♿ </span>
                            }
                            @if (p.isUnderground == true)
                            {
                                <span title="Garaža">🏢 </span>
                            }
                        </td>
                        <td>
                            <div style="display:flex;gap:6px;">
                                <a href="/Admin/ParkingDetails/@p.ID" style="padding:5px 12px;background:var(--surface2);color:var(--accent);border:1px solid var(--border);border-radius:6px;font-size:12px;text-decoration:none;">Pregledaj</a>                                <a href="/Parking/Edit/@p.ID" style="padding:5px 12px;background:#fff8e1;color:#f59e0b;border:1px solid #fcd34d;border-radius:6px;font-size:12px;text-decoration:none;">Uredi</a>
                                <form asp-action="DeleteParking" method="post" onsubmit="event.preventDefault();admConfirm(this,'Brisanje parkinga','Jeste li sigurni da želite obrisati parking &quot;@p.name&quot; i sve njegove rezervacije?');">
                                    <input type="hidden" name="id" value="@p.ID" />
                                    <button type="submit" style="padding:5px 12px;background:#fdf0f0;color:#dc3545;border:1px solid #f5c6cb;border-radius:6px;font-size:12px;cursor:pointer;">Obriši</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>


@section Scripts {
    <partial name="_AdminStyles" />
}
