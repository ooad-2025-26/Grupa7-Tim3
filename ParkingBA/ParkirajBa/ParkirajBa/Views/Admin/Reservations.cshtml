@model IEnumerable<ParkirajBa.Models.Ticket>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Rezervacije";
    string statusFilter = ViewBag.StatusFilter ?? "";
    var now = DateTime.Now;
}

<partial name="_AdminStyles" />

<div class="adm-wrapper">
    <partial name="_AdminSidebar" />

    <main class="adm-content">

        <div class="adm-page-header">
            <div>
                <h1 class="adm-page-title">Rezervacije</h1>
                <p class="adm-page-sub">Pregled svih rezervacija u sistemu</p>
            </div>
            <span class="adm-badge blue" style="font-size:13px;padding:6px 14px;">@Model.Count() ukupno</span>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="adm-alert-success">✓ @TempData["Success"]</div>
        }

        <!-- Filter pills -->
        <div class="adm-filters">
            @foreach (var (label, value) in new[] { ("Sve", ""), ("Aktivne", "active"), ("Istekle", "expired"), ("Plaćene", "paid"), ("Neplaćene", "unpaid") })
            {
                <a href="/Admin/Reservations@(value == "" ? "" : "?status=" + value)"
                   class="adm-filter-pill @(statusFilter == value ? "active" : "")">@label</a>
            }
        </div>

        <div class="adm-card" style="overflow:hidden;">
            <table class="adm-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Korisnik</th>
                        <th>Parking</th>
                        <th>Kreirano</th>
                        <th>Ističe</th>
                        <th>Iznos</th>
                        <th>Status</th>
                        <th>Akcije</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model)
                    {
                        bool isActive = t.IssuedAt <= now && (!t.ExpiresAt.HasValue || t.ExpiresAt >= now);
                        bool isExpired = t.ExpiresAt.HasValue && t.ExpiresAt < now;
                        <tr>
                            <td style="color:var(--adm-text3);font-size:12px;">#@t.Id</td>
                            <td>
                                <div style="font-weight:600;">@(t.ApplicationUser?.FullName ?? "—")</div>
                                <div style="font-size:11px;color:var(--adm-text3);">@(t.ApplicationUser?.Email ?? "")</div>
                            </td>
                            <td>@(t.ParkingObject?.name ?? "—")</td>
                            <td style="font-size:12px;color:var(--adm-text2);">@t.IssuedAt.ToString("dd.MM.yy HH:mm")</td>
                            <td style="font-size:12px;color:var(--adm-text2);">@(t.ExpiresAt.HasValue ? t.ExpiresAt.Value.ToString("dd.MM.yy HH:mm") : "—")</td>
                            <td style="font-weight:700;color:var(--adm-accent);">@t.Price.ToString("0.00") KM</td>
                            <td>
                                @if (t.IsPaid)
                                {
                                    <span class="adm-badge green">Plaćeno</span>
                                }
                                else if (isExpired)
                                {

                                    <span class="adm-badge gray">Isteklo</span>
                                }
                                else if (isActive)
                                {

                                    <span class="adm-badge orange">U tijeku</span>
                                }
                                else
                                {

                                    <span class="adm-badge blue">Na čekanju</span>
                                }
                            </td>
                            <td>
                                <div style="display:flex;gap:6px;">
                                    <a href="/Admin/ReservationDetails/@t.Id" class="adm-btn adm-btn-outline adm-btn-sm">Pregledaj</a>
                                    <form asp-action="DeleteReservation" method="post"
                                          onsubmit="event.preventDefault();admConfirm(this,'Brisanje rezervacije','Jeste li sigurni da želite obrisati rezervaciju #@t.Id?');">
                                        <input type="hidden" name="id" value="@t.Id" />
                                        <button type="submit" class="adm-btn adm-btn-danger adm-btn-sm">Obriši</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </main>
</div>
