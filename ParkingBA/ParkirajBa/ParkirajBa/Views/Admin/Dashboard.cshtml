@model List<ParkirajBa.Controllers.AdminUserViewModel>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Admin Panel";

    int userCount = ViewBag.UserCount ?? 0;
    int ownerCount = ViewBag.OwnerCount ?? 0;
    int regularCount = ViewBag.RegularCount ?? 0;
    int totalTickets = ViewBag.TotalTickets ?? 0;
    int activeTickets = ViewBag.ActiveTickets ?? 0;
    int paidTickets = ViewBag.PaidTickets ?? 0;
    decimal totalRevenue = ViewBag.TotalRevenue ?? 0m;
    decimal revenueThisMonth = ViewBag.RevenueThisMonth ?? 0m;
    decimal revenueLastMonth = ViewBag.RevenueLastMonth ?? 0m;
    int totalParkings = ViewBag.TotalParkings ?? 0;
    int totalSpots = ViewBag.TotalSpots ?? 0;
    int availableSpots = ViewBag.AvailableSpots ?? 0;
    var recentTickets = ViewBag.RecentTickets as List<ParkirajBa.Models.Ticket> ?? new();
    decimal revChange = revenueLastMonth > 0 ? Math.Round((revenueThisMonth - revenueLastMonth) / revenueLastMonth * 100, 1) : 0;
}

<style>
    .dashboard-custom-card {
        background: #ffffff !important;
        border: 1px solid #e2e8f0 !important;
        border-radius: 12px !important;
        padding: 20px !important;
    }

    .dashboard-kpi-card-fix {
        background: #ffffff !important;
        border: 1px solid #e2e8f0 !important;
        border-radius: 12px !important;
        padding: 20px !important;
        display: flex !important;
        align-items: center !important;
        gap: 16px !important;
    }
    /* Stilovi za gornju navigaciju */
    .nav-link-custom {
        color: #2d3748 !important;
        font-size: 14px;
        font-weight: 600;
        text-decoration: none;
        padding: 8px 16px;
        border-radius: 8px;
        transition: background 0.2s;
    }

        .nav-link-custom:hover {
            background: #edf2f7;
        }

    .nav-link-active-custom {
        background: #3182ce !important;
        color: white !important;
        font-size: 14px;
        font-weight: 600;
        text-decoration: none;
        padding: 8px 16px;
        border-radius: 8px;
    }
</style>

<div style="min-height:100vh;background:#f7fafc;padding:28px 36px;">

    @* GORNJA SEKCIJA: Naslov i Navigacija koja je bila nevidljiva *@
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:28px;flex-wrap:wrap;gap:12px;">
        <div>
            <h1 style="margin:0;font-size:26px;font-weight:700;color:#1a202c;">Admin Panel</h1>
            <p style="margin:4px 0 0;color:#718096;font-size:14px;">@DateTime.Now.ToString("dddd, dd MMMM yyyy")</p>
        </div>
        @* POPRAVLJENO: Linkovi su sada tamni i jasno vidljivi, a "Izvještaji" ima fiksiranu plavu pozadinu *@
        <div style="display:flex;gap:6px;flex-wrap:wrap;align-items:center;">
            <a href="/Admin/Users" class="nav-link-custom">Korisnici</a>
            <a href="/Admin/Parkings" class="nav-link-custom">Parkinzi</a>
            <a href="/Admin/Reservations" class="nav-link-custom">Rezervacije</a>
            <a href="/Admin/Reports" class="nav-link-active-custom">Izvještaji</a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="adm-alert-success">✓ @TempData["Success"]</div>
    }

    @* KPI KARTICE: Zamijenjene varijable stabilnim bojama teksta *@
    <div class="adm-grid-4" style="margin-bottom:20px; display:grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap:20px;">

        @* Korisnici *@
        <div class="dashboard-kpi-card-fix">
            <div style="background:#eef1ff; padding:12px; border-radius:10px; display:flex; align-items:center; justify-content:center;">
                <svg viewBox="0 0 24 24" width="24" height="24" fill="#6287f9"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z" /></svg>
            </div>
            <div>
                <div style="font-size:24px; font-weight:700; color:#1a202c;">@userCount</div>
                <div style="font-size:13px; color:#718096; font-weight:500;">Ukupno korisnika</div>
                <div style="font-size:11px; color:#a0aec0;">@regularCount obični · @ownerCount vlasnika</div>
            </div>
        </div>

        @* Rezervacije *@
        <div class="dashboard-kpi-card-fix">
            <div style="background:#fff3e0; padding:12px; border-radius:10px; display:flex; align-items:center; justify-content:center;">
                <svg viewBox="0 0 24 24" width="24" height="24" fill="#ff9800"><path d="M17 12h-5v5h5v-5zM16 1v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2h-1V1h-2zm3 18H5V8h14v11z" /></svg>
            </div>
            <div>
                <div style="font-size:24px; font-weight:700; color:#1a202c;">@totalTickets</div>
                <div style="font-size:13px; color:#718096; font-weight:500;">Ukupno rezerv
