@{
    Layout = "_Layout";
    ViewData["Title"] = "Produženje rezervacije";

    var ticket = ViewBag.Ticket as ParkirajBa.Models.Ticket;
    var parking = ViewBag.Parking as ParkirajBa.Models.ParkingObject;
    var pricings = ViewBag.Pricings as List<ParkirajBa.Models.Pricing>;

    var hourlyPricing = pricings?.FirstOrDefault(p => p.pricingType == ParkirajBa.Models.PricingType.Hourly);
    decimal pricePerHour = hourlyPricing?.price ?? 0;
}

<div class="app-container">

    <div class="tabs">
        <div class="tab"><a href="/Home/Index">Mapa</a></div>
        <div class="tab"><a href="/Home/Objekti">Objekti</a></div>
        <div class="tab active"><a href="/Home/Rezervacije">Rezervacije</a></div>
    </div>

    <div class="rezervacije-container">

        <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 24px;">
            <a href="/Reservation/Details/@ticket?.Id" style="color: #6287f9; font-size: 14px; display: inline-flex; align-items: center; gap: 4px; text-decoration: none; font-weight: 500;">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="#6287f9"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z" /></svg>
                Nazad na rezervaciju
            </a>
        </div>

        @if (TempData["Error"] != null)
        {
            <div style="margin-bottom: 16px; background:#fdf0f0; color:#dc3545; padding:12px; border-radius:8px;">@TempData["Error"]</div>
        }

        <!-- Info kartica -->
        <div style="background: white; border-radius: 16px; padding: 24px 28px; box-shadow: 0 3px 14px rgba(0,0,0,0.07); margin-bottom: 20px;">
            <h2 style="margin: 0 0 6px; font-size: 20px; color: #222;">Produženje rezervacije</h2>
            <p style="margin: 0 0 20px; color: #777; font-size: 14px;">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="#aaa" style="vertical-align: middle; margin-right: 4px;"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" /></svg>
                @(parking?.name ?? "Parking") &mdash; @(parking?.address ?? "")
            </p>

            <!-- Trenutno ističe -->
            <div style="display: flex; gap: 12px; background: #f8f9ff; border-radius: 12px; padding: 16px 20px; margin-bottom: 24px; border: 1px solid #e8ecff;">
                <div style="flex: 1;">
                    <div style="font-size: 11px; color: #999; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px;">Trenutno ističe</div>
                    <div style="font-size: 18px; font-weight: 700; color: #e67e22;">
                        @(ticket?.ExpiresAt?.ToString("dd.MM.yyyy HH:mm") ?? "—")
                    </div>
                </div>
                <div style="display: flex; align-items: center; color: #bbb;">
                    <svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor"><path d="M8 5v14l11-7z" /></svg>
                </div>
                <div style="flex: 1;" id="noviIstekPanel">
                    <div style="font-size: 11px; color: #999; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px;">Novi rok isteka</div>
                    <div style="font-size: 18px; font-weight: 700; color: #27ae60;" id="noviIstekVrijeme">—</div>
                </div>
            </div>

            <!-- Izbor sati -->
            <form asp-controller="Reservation" asp-action="Extend" method="post" id="extendForm">
                <input type="hidden" name="id" value="@ticket?.Id" />

                <div style="margin-bottom: 20px;">
                    <label style="display: block; font-size: 13px; font-weight: 600; color: #444; margin-bottom: 10px;">Odaberite broj sati produženja</label>

                    <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px;" id="satGrid">
                        @foreach (int sat in new[] { 1, 2, 3, 4, 6, 8, 12, 24 })
                        {
                            <button type="button"
                                    class="sat-btn"
                                    data-sati="@sat"
                                    onclick="odaberiSate(@sat)">
                                @sat h
                            </button>
                        }
                    </div>

                    <input type="hidden" name="extraHours" id="extraHoursInput" value="1" />
                </div>

                <!-- Cijena -->
                <div style="background: #f8f9fa; border-radius: 12px; padding: 16px 20px; margin-bottom: 24px;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                        <span style="color: #777; font-size: 14px;">Cijena po satu</span>
                        <span style="font-weight: 600; color: #333;">@pricePerHour.ToString("0.00") KM</span>
                    </div>
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                        <span style="color: #777; font-size: 14px;">Broj sati</span>
                        <span style="font-weight: 600; color: #333;" id="prikaz-sati">1</span>
                    </div>
                    <div style="border-top: 1px solid #e9ecef; margin: 10px 0;"></div>
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <span style="font-weight: 700; color: #333;">Ukupno za platiti</span>
                        <span style="font-size: 20px; font-weight: 700; color: #6287f9;" id="prikaz-cijena">@pricePerHour.ToString("0.00") KM</span>
                    </div>
                </div>

                <button type="submit" class="btn-blue" style="width: 100%; text-align: center; font-size: 15px; padding: 14px;">
                    Nastavi na plaćanje
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" style="vertical-align: middle; margin-left: 6px;"><path d="M8 5v14l11-7z" /></svg>
                </button>
            </form>
        </div>

    </div>
</div>

<style>
    .sat-btn {
        padding: 12px 6px;
        border: 2px solid #e0e6ff;
        border-radius: 10px;
        background: white;
        color: #6287f9;
        font-weight: 600;
        font-size: 15px;
        cursor: pointer;
        transition: all 0.15s;
    }

        .sat-btn:hover {
            border-color: #6287f9;
            background: #f0f3ff;
        }

        .sat-btn.aktivan {
            border-color: #6287f9;
            background: #6287f9;
            color: white;
        }
</style>

<script>
    const pricePerHour = @pricePerHour.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture);
    const currentExpiry = new Date('@(ticket?.ExpiresAt?.ToString("o") ?? DateTime.Now.ToString("o"))');

    function odaberiSate(sati) {
        document.querySelectorAll('.sat-btn').forEach(b => b.classList.remove('aktivan'));
        const btn = document.querySelector(`.sat-btn[data-sati="${sati}"]`);
        if (btn) btn.classList.add('aktivan');

        document.getElementById('extraHoursInput').value = sati;
        document.getElementById('prikaz-sati').textContent = sati;
        document.getElementById('prikaz-cijena').textContent = (pricePerHour * sati).toFixed(2) + ' KM';

        // Novi rok isteka
        const noviIstekDatum = new Date(currentExpiry.getTime() + sati * 3600 * 1000);
        document.getElementById('noviIstekVrijeme').textContent = formatDatum(noviIstekDatum);
    }

    function formatDatum(d) {
        const pad = n => String(n).padStart(2, '0');
        return `${pad(d.getDate())}.${pad(d.getMonth()+1)}.${d.getFullYear()} ${pad(d.getHours())}:${pad(d.getMinutes())}`;
    }

    // Default: 1h aktivan
    document.addEventListener('DOMContentLoaded', () => odaberiSate(1));
</script>
