@{
    Layout = null;
}

<link rel="stylesheet" href="/css/site.css" />

<div class="main-container">
    <header class="top-header">
        <div class="header-center">
            <img src="/images/logo.png" alt="ParkirajBa Logo" class="header-logo" />
        </div>
        <div class="header-right">
            <div class="user-pill">
                <span class="user-name">Ime Prezime</span>
                <div class="user-icon">
                    <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
                        <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
                    </svg>
                </div>
            </div>
        </div>
    </header>

    <div class="map-layer">
        <img src="/images/map.png" alt="Mapa" />
    </div>

    <div class="custom-overlay"></div>

    <div class="content-wrapper">
        <div class="payment-card">
            <h2 class="pay-title" style="margin-top: 30px;">Plaćanje</h2>
    
            <div class="stepper">
                <div class="circle active"></div>
                <div class="line active"></div>
                <div class="circle active"></div>
                <div class="line active"></div>
                <div class="circle active"></div>
            </div>

            <div class="form-body">
                <div style="margin: 20px 0;">
                    <svg viewBox="0 0 24 24" width="80" height="80" fill="#6287f9">
                        <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z" />
                    </svg>
                </div>

                <p style="font-size: 16px; color: #555; margin-bottom: 30px; padding: 0 20px; line-height: 1.5;">
                    Potvrda uplate i pristup parkingu poslani na Vaš e-mail.
                </p>

                <div class="footer-buttons">
                    <a href="/" class="btn-blue" style="width: 100%; text-decoration: none;">Završi</a>
                </div>
            </div>
        </div>
    </div>
</div>

