@{
    Layout = "_Layout";
    ViewData["Title"] = "Uspjeh";
    ViewBag.HideHeader = true;
}

<div class="main-container">

    <div class="map-layer">
        <img src="/images/map.png" alt="Mapa" />
    </div>

    <div class="custom-overlay"></div>

    @await Html.PartialAsync("_PaymentHeader")

    <div class="content-wrapper">
        <div class="payment-card confirmation-style">
            <h2 class="pay-title" style="margin-top: 30px;">Plaćanje</h2>

            <div class="stepper">
                <div class="circle active"></div>
                <div class="line active"></div>
                <div class="circle active"></div>
                <div class="line active"></div>
                <div class="circle active"></div>
            </div>

            <div class="form-body">
                <div style="margin: 20px 0;">
                    <svg viewBox="0 0 24 24" width="80" height="80" fill="#6287f9">
                        <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z" />
                    </svg>
                </div>

                <p style="font-size: 16px; color: #555; margin-bottom: 30px; padding: 0 20px; line-height: 1.5;">
                    Potvrda uplate i pristup parkingu poslani na Vaš e-mail.
                </p>

                <div class="footer-buttons">
                    <a href="/" class="btn-blue" style="width: 100%; text-decoration: none;">Završi</a>
                </div>
            </div>
        </div>
    </div>
</div>
