@{
    Layout = null;
}


<link rel="stylesheet" href="/css/site.css" />

<div class="main-container">
    <header class="top-header">
        <div class="header-center">
            <img src="/images/logo.png" alt="ParkirajBa Logo" class="header-logo" />
        </div>
        <div class="header-right">
            <div class="user-pill">
                <span class="user-name">Ime Prezime</span>
                <div class="user-icon">
                    <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
                        <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
                    </svg>
                </div>
            </div>
        </div>
    </header>

    <div class="map-layer">
        <img src="/images/map.png" alt="Mapa" />
    </div>

    <div class="custom-overlay"></div>

    <div class="content-wrapper">
        <div class="payment-card">
            <div class="card-header">
                <a href="/" class="btn-back-link">&lt; Nazad na početnu</a>
            </div>

            <h2 class="pay-title">Plaćanje</h2>
    
            <div class="stepper">
                <div class="circle active"></div>
                <div class="line"></div>
                <div class="circle"></div>
                <div class="line"></div>
                <div class="circle"></div>
            </div>

            <div class="form-body">
                <p class="section-label">Lične informacije</p>
        
                <input type="text" id="cardName" placeholder="Ime i prezime vlasnika kartice*" class="custom-input" />
                <input type="text" id="cardNumber" placeholder="Broj kartice*" class="custom-input" maxlength="19" />
        
                <div class="input-row">
                    <input type="text" id="expiryDate" placeholder="MM/YY*" class="custom-input" maxlength="5" />
                    <input type="text" id="cvv" placeholder="CVV*" class="custom-input" maxlength="4" />
                </div>

                <div class="footer-buttons">
                    <button class="btn-gray"> Nazad </button>
                    <button id="btnSubmit" class="btn-blue">Dalje</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('btnSubmit').addEventListener('click', function () {
        const cardName = document.getElementById('cardName');
        const cardNumber = document.getElementById('cardNumber');
        const expiryDate = document.getElementById('expiryDate');
        const cvv = document.getElementById('cvv');

        let isValid = true;

        if (cardName.value.trim().length < 3) {
            cardName.classList.add('input-error');
            isValid = false;
        } else {
            cardName.classList.remove('input-error');
        }

        const cleanNumber = cardNumber.value.replace(/\s+/g, '');
        if (!validateLuhn(cleanNumber) || cleanNumber.length < 13) {
            cardNumber.classList.add('input-error');
            isValid = false;
        } else {
            cardNumber.classList.remove('input-error');
        }

        const dateRegex = /^(0[1-9]|1[0-2])\/?([0-9]{2})$/;
        if (!dateRegex.test(expiryDate.value)) {
            expiryDate.classList.add('input-error');
            isValid = false;
        } else {
            expiryDate.classList.remove('input-error');
        }

        const cvvRegex = /^[0-9]{3,4}$/;
        if (!cvvRegex.test(cvv.value)) {
            cvv.classList.add('input-error');
            isValid = false;
        } else {
            cvv.classList.remove('input-error');
        }

        if (isValid) {
            const name = encodeURIComponent(cardName.value);
            window.location.href = '/Payment/Potvrda?ime=' + name;
        }
    });

    //validation algorithm for card number
    function validateLuhn(number) {
        let sum = 0;
        let shouldDouble = false;
        for (let i = number.length - 1; i >= 0; i--) {
            let digit = parseInt(number.charAt(i));
            if (shouldDouble) {
                if ((digit *= 2) > 9) digit -= 9;
            }
            sum += digit;
            shouldDouble = !shouldDouble;
        }
        return (sum % 10) === 0;
    }

    cardNumber.addEventListener('input', (e) => {
        e.target.value = e.target.value.replace(/[^\d]/g, '').replace(/(.{4})/g, '$1 ').trim();
    });

    expiryDate.addEventListener('input', (e) => {
        e.target.value = e.target.value.replace(/[^\d]/g, '').replace(/(.{2})/, '$1/').trim();
    });
</script>