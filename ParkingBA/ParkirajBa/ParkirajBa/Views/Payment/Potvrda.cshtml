@{
    Layout = "_Layout";
    ViewData["Title"] = "Potvrda";
    ViewBag.HideHeader = true;
}

<div class="main-container">

    <div class="map-layer">
        <img src="/images/map.png" alt="Mapa" />
    </div>

    <div class="custom-overlay"></div>

    @await Html.PartialAsync("_PaymentHeader")

    <div class="content-wrapper">
        <div class="payment-card confirmation-style">
            <div class="payment-card-top">
                <a href="/" class="btn-back-link">&lt; Nazad na početnu</a>
            </div>

            <h2 class="pay-title">Plaćanje</h2>

            <div class="stepper">
                <div class="circle active"></div>
                <div class="line active"></div>
                <div class="circle active"></div>
                <div class="line"></div>
                <div class="circle"></div>
            </div>

            <div class="form-body">
                <div class="confirm-box">
                    <p style="margin: 0; color: #555; font-size: 15px;">
                        Na ime <strong>@ViewBag.ImeKorisnika</strong> rezervišete zakup, želite li nastaviti?
                    </p>
                </div>

                <div class="footer-buttons">
                    <button onclick="window.history.back()" class="btn-gray">Nazad</button>

                    <form asp-action="PosaljiEmail" method="post" style="flex: 1; display: flex;">
                        <input type="hidden" name="ime" value="@ViewBag.ImeKorisnika" />
                        <button type="submit" class="btn-blue" style="width: 100%;">Potvrdi podatke</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
