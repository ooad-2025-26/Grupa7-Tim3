@model dynamic
@{
    Layout = "_Layout";
    ViewData["Title"] = "Plaćanje";
    var ticket = ViewBag.Ticket as ParkirajBa.Models.Ticket;
    string fullName = ViewBag.UserFullName ?? "";
}

<div class="main-container">
    <div class="map-layer"><img src="/images/map.png" alt="Mapa" /></div>
    <div class="custom-overlay"></div>

    <div class="content-wrapper" style="margin-top: 80px;">
        <div class="payment-card">
            <div class="payment-card-top" style="padding-top: 12px;">
                <a href="/Reservation/Details/@ticket?.Id" class="btn-back-link">&lt; Nazad na rezervaciju</a>
            </div>

            <h2 class="pay-title">Plaćanje</h2>

            <div class="stepper">
                <div class="circle active"></div>
                <div class="line"></div>
                <div class="circle"></div>
                <div class="line"></div>
                <div class="circle"></div>
            </div>

            @if (ticket != null)
            {
                <div style="background:#f4f7ff;border-radius:12px;padding:14px 18px;margin-bottom:18px;display:flex;justify-content:space-between;align-items:center;">
                    <div>
                        <div style="font-size:13px;color:#888;">Parking objekat</div>
                        <div style="font-weight:600;color:#333;">@(ticket.ParkingObject?.name ?? "Parking")</div>
                        <div style="font-size:12px;color:#aaa;">Vrijedi do @(ticket.ExpiresAt.HasValue ? ticket.ExpiresAt.Value.ToString("dd.MM.yyyy HH:mm") : "—")</div>
                    </div>
                    <div style="text-align:right;">
                        <div style="font-size:22px;font-weight:700;color:#6287f9;">
                            @((ViewBag.IsAdditionalCharge
                                                    ? ticket.AdditionalCharge
                                                    : ticket.Price).ToString("0.00")) KM
                    </div>
                    </div>
                </div>
            }

            <div class="form-body">
                <p class="section-label">Detalji kartice</p>

                <input type="text" id="cardName" placeholder="Ime i prezime na kartici*" class="custom-input" value="@fullName" />
                <input type="text" id="cardNumber" placeholder="Broj kartice*" class="custom-input" maxlength="19" />

                <div class="input-row">
                    <input type="text" id="expiryDate" placeholder="MM/GG*" class="custom-input" maxlength="5" />
                    <input type="text" id="cvv" placeholder="CVV*" class="custom-input" maxlength="4" />
                </div>

                <div class="footer-buttons">
                    <button class="btn-gray" onclick="history.back()">Nazad</button>
                    <button id="btnSubmit" class="btn-blue">Nastavi</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const ticketId = @(ViewBag.FromSession == true ? 0 : (ticket?.Id ?? 0));
        const fromSession = @(ViewBag.FromSession == true ? "true" : "false");

        document.getElementById('btnSubmit').addEventListener('click', function () {
            const cardName = document.getElementById('cardName');
            const cardNumber = document.getElementById('cardNumber');
            const expiryDate = document.getElementById('expiryDate');
            const cvv = document.getElementById('cvv');
            let isValid = true;

            [cardName, cardNumber, expiryDate, cvv].forEach(f => f.classList.remove('input-error'));

            if (cardName.value.trim().length < 3) { cardName.classList.add('input-error'); isValid = false; }

            const cleanNum = cardNumber.value.replace(/\s+/g, '');
            if (!validateLuhn(cleanNum) || cleanNum.length < 13) { cardNumber.classList.add('input-error'); isValid = false; }

            const dateRegex = /^(0[1-9]|1[0-2])\/([0-9]{2})$/;
            if (!dateRegex.test(expiryDate.value)) {
                expiryDate.classList.add('input-error'); isValid = false;
            } else {
                const [m, y] = expiryDate.value.split('/');
                if (new Date(2000 + parseInt(y), parseInt(m)) <= new Date()) {
                    expiryDate.classList.add('input-error'); isValid = false;
                }
            }

            if (!/^[0-9]{3,4}$/.test(cvv.value)) { cvv.classList.add('input-error'); isValid = false; }

            if (isValid) {
                window.location.href = '/Payment/Confirm?cardName=' + encodeURIComponent(cardName.value) + '&ticketId=' + ticketId + '&fromSession=' + fromSession;
            }
        });

        function validateLuhn(n) {
            let sum = 0, d = false;
            for (let i = n.length - 1; i >= 0; i--) {
                let dig = parseInt(n[i]);
                if (d && (dig *= 2) > 9) dig -= 9;
                sum += dig; d = !d;
            }
            return sum % 10 === 0;
        }

        document.getElementById('cardNumber').addEventListener('input', e => {
            e.target.value = e.target.value.replace(/[^\d]/g, '').replace(/(.{4})/g, '$1 ').trim();
        });
        document.getElementById('expiryDate').addEventListener('input', e => {
            e.target.value = e.target.value.replace(/[^\d]/g, '').replace(/^(.{2})/, '$1/').substring(0, 5);
        });
    </script>
}
