<style>
    .adm-grid-4 {
        display: grid;
        grid-template-columns: repeat(4,1fr);
        gap: 18px;
    }

    .adm-kpi-card {
        background: var(--surface);
        border-radius: 16px;
        padding: 20px;
        display: flex;
        align-items: center;
        gap: 16px;
        box-shadow: var(--card-shadow);
        border: 1px solid var(--border);
    }

    .adm-kpi-icon {
        width: 50px;
        height: 50px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .adm-kpi-value {
        font-size: 22px;
        font-weight: 700;
        color: var(--text);
        line-height: 1;
    }

    .adm-kpi-label {
        font-size: 12px;
        color: var(--text2);
        margin-top: 2px;
    }

    .adm-kpi-sub {
        font-size: 11px;
        color: var(--text3);
        margin-top: 2px;
    }

    .adm-card {
        background: var(--surface);
        border-radius: 16px;
        padding: 22px 26px;
        box-shadow: var(--card-shadow);
        border: 1px solid var(--border);
    }

    .adm-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-weight: 600;
        color: var(--text);
        font-size: 15px;
        margin-bottom: 14px;
    }

    .adm-stat-box {
        background: var(--surface2);
        border-radius: 10px;
        padding: 14px;
        border: 1px solid var(--border);
    }

    .adm-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

        .adm-table th {
            text-align: left;
            padding: 10px 14px;
            background: var(--surface2);
            color: var(--text3);
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: .5px;
            font-weight: 600;
        }

        .adm-table td {
            padding: 12px 14px;
            border-bottom: 1px solid var(--border);
            color: var(--text);
        }

        .adm-table tr:last-child td {
            border-bottom: none;
        }

    .adm-badge {
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 600;
        display: inline-block;
    }

        .adm-badge.green {
            background: #d4edda;
            color: #155724;
        }

        .adm-badge.blue {
            background: #dce8ff;
            color: #1a56db;
        }

        .adm-badge.gray {
            background: #e9ecef;
            color: #6c757d;
        }

        .adm-badge.orange {
            background: #fff3cd;
            color: #856404;
        }

    .adm-btn-primary {
        background: var(--accent);
        color: white !important;
        padding: 10px 20px;
        border-radius: 10px;
        text-decoration: none;
        font-size: 13px;
        font-weight: 600;
    }

    .adm-btn-outline {
        border: 1px solid var(--border);
        color: var(--text2) !important;
        padding: 10px 20px;
        border-radius: 10px;
        text-decoration: none;
        font-size: 13px;
        font-weight: 500;
    }

        .adm-btn-outline:hover {
            border-color: var(--accent);
            color: var(--accent) !important;
        }

    .adm-alert-success {
        background: #d4edda;
        color: #155724;
        padding: 12px 18px;
        border-radius: 10px;
        margin-bottom: 20px;
        font-size: 14px;
    }

    .adm-confirm-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.55);
        z-index: 9999;
        align-items: center;
        justify-content: center;
    }

        .adm-confirm-overlay.show {
            display: flex;
        }

    .adm-confirm-box {
        background: #ffffff;
        border-radius: 16px;
        padding: 28px 32px;
        max-width: 380px;
        width: 90%;
        box-shadow: 0 20px 60px rgba(0,0,0,0.3);
        border: 1px solid var(--border);
        text-align: center;
    }

        .adm-confirm-box h3 {
            margin: 0 0 10px;
            font-size: 17px;
            color: var(--text);
        }

        .adm-confirm-box p {
            margin: 0 0 22px;
            font-size: 14px;
            color: var(--text2);
        }

    .adm-confirm-btns {
        display: flex;
        gap: 10px;
        justify-content: center;
    }

        .adm-confirm-btns .btn-cancel {
            padding: 10px 24px;
            border-radius: 10px;
            background: var(--surface2);
            color: var(--text2);
            border: 1px solid var(--border);
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
        }

        .adm-confirm-btns .btn-confirm-del {
            padding: 10px 24px;
            border-radius: 10px;
            background: #dc3545;
            color: white;
            border: none;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
        }
</style>

<!-- Custom confirm popup -->
<div id="admConfirmOverlay" class="adm-confirm-overlay">
    <div class="adm-confirm-box">
        <h3 id="admConfirmTitle">Potvrda brisanja</h3>
        <p id="admConfirmMsg">Jeste li sigurni da želite obrisati ovu stavku?</p>
        <div class="adm-confirm-btns">
            <button class="btn-cancel" onclick="admConfirmClose()">Odustani</button>
            <button class="btn-confirm-del" id="admConfirmBtn">Obriši</button>
        </div>
    </div>
</div>

<script>
    let _pendingForm = null;

    function admConfirm(formEl, title, msg) {
        _pendingForm = formEl;
        document.getElementById('admConfirmTitle').textContent = title || 'Potvrda brisanja';
        document.getElementById('admConfirmMsg').textContent = msg || 'Jeste li sigurni?';
        document.getElementById('admConfirmOverlay').classList.add('show');
    }
    function admConfirmClose() {
        document.getElementById('admConfirmOverlay').classList.remove('show');
        _pendingForm = null;
    }
    document.getElementById('admConfirmBtn').onclick = function () {
        if (_pendingForm) _pendingForm.submit();
        admConfirmClose();
    };
    document.getElementById('admConfirmOverlay').addEventListener('click', function (e) {
        if (e.target === this) admConfirmClose();
    });
</script>
