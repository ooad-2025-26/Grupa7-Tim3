@{
    var current = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    string NavClass(string c, string a) =>
        (ctrl.Equals(c, StringComparison.OrdinalIgnoreCase) && (a == "*" || current.Equals(a, StringComparison.OrdinalIgnoreCase)))
        ? "adm-nav-link active" : "adm-nav-link";
}
